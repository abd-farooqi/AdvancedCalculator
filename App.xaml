<Application x:Class="AdvancedCalculator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <SolidColorBrush x:Key="BgPrimary" Color="#1a1a2e"/>
            <SolidColorBrush x:Key="BgSecondary" Color="#16213e"/>
            <SolidColorBrush x:Key="BgTertiary" Color="#0f3460"/>
            <SolidColorBrush x:Key="Accent" Color="#e94560"/>
            <SolidColorBrush x:Key="AccentHover" Color="#ff6b81"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#ffffff"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#a0a0b0"/>
            <SolidColorBrush x:Key="BtnNumber" Color="#2a2a4a"/>
            <SolidColorBrush x:Key="BtnNumberHover" Color="#3a3a5a"/>
            <SolidColorBrush x:Key="BtnOperator" Color="#3a3a6a"/>
            <SolidColorBrush x:Key="BtnOperatorHover" Color="#4a4a7a"/>
            <SolidColorBrush x:Key="BtnFunction" Color="#1a3a5a"/>
            <SolidColorBrush x:Key="BtnFunctionHover" Color="#2a4a6a"/>
            <SolidColorBrush x:Key="BtnEquals" Color="#e94560"/>
            <SolidColorBrush x:Key="BtnEqualsHover" Color="#ff6b81"/>
            <SolidColorBrush x:Key="BtnClear" Color="#5a2a3a"/>
            <SolidColorBrush x:Key="BtnClearHover" Color="#7a3a4a"/>
            <SolidColorBrush x:Key="GlassBorder" Color="#4a4a8a" Opacity="0.3"/>
            <SolidColorBrush x:Key="Success" Color="#4ade80"/>
            <SolidColorBrush x:Key="Warning" Color="#fbbf24"/>
            
            <!-- Fonts -->
            <FontFamily x:Key="DisplayFont">Consolas, Courier New</FontFamily>
            <FontFamily x:Key="ButtonFont">Segoe UI, Arial</FontFamily>
            
            <!-- Display Style -->
            <Style x:Key="DisplayStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            
            <!-- Tab Style -->
            <Style TargetType="TabItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="border" Background="Transparent" BorderThickness="0" Padding="20,8" Margin="2,0" CornerRadius="8,8,0,0">
                                <TextBlock x:Name="text" Text="{TemplateBinding Header}" Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource ButtonFont}" FontSize="14" FontWeight="SemiBold" TextAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource BgTertiary}"/>
                                    <Setter TargetName="text" Property="Foreground" Value="{StaticResource Accent}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="text" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Tab Control Style -->
            <Style TargetType="TabControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="12,12,0,0">
                                    <TabPanel IsItemsHost="True" Margin="10,10,10,0"/>
                                </Border>
                                <Border Grid.Row="1" Background="{StaticResource BgPrimary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="0,0,12,12">
                                    <ContentPresenter ContentSource="SelectedContent"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Calc Button Base Style -->
            <Style x:Key="CalcButton" TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource ButtonFont}"/>
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="Background" Value="{StaticResource BtnNumber}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource BtnNumberHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="border" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Operator Button Style -->
            <Style x:Key="OperatorButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
                <Setter Property="Background" Value="{StaticResource BtnOperator}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="20"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BtnOperatorHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            
            <!-- Function Button Style -->
            <Style x:Key="FunctionButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
                <Setter Property="Background" Value="{StaticResource BtnFunction}"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BtnFunctionHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            
            <!-- Equals Button Style -->
            <Style x:Key="EqualsButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
                <Setter Property="Background" Value="{StaticResource BtnEquals}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="24"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BtnEqualsHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            
            <!-- Clear Button Style -->
            <Style x:Key="ClearButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
                <Setter Property="Background" Value="{StaticResource BtnClear}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BtnClearHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            
            <!-- Memory Display Style -->
            <Style x:Key="MemoryStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
                <Setter Property="Foreground" Value="{StaticResource Success}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
            
            <!-- Label Style -->
            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontFamily" Value="{StaticResource ButtonFont}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            
            <!-- Value Style -->
            <Style x:Key="ValueStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
                <Setter Property="FontSize" Value="18"/>
            </Style>
            
            <!-- Result Box Style -->
            <Style x:Key="ResultBoxStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource GlassBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="15"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
