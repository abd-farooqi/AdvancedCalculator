<Window x:Class="AdvancedCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Calculator" Height="680" Width="450"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowState="Normal">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>
    
    <Border Background="{StaticResource BgPrimary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="{StaticResource BgSecondary}" MouseLeftButtonDown="TitleBar_MouseDown" MouseLeftButtonUp="TitleBar_MouseUp" MouseMove="TitleBar_MouseMove">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Advanced Calculator" Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0" IsHitTestVisible="False"/>
                
                <Button x:Name="MinimizeBtn" Grid.Column="1" Content="─" Width="36" Height="30" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" FontSize="14" Click="Minimize_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="Background" Value="rgba(255,255,255,0.1)"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <Button x:Name="MaximizeBtn" Grid.Column="2" Content="□" Width="36" Height="30" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" FontSize="14" Click="Maximize_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <Button x:Name="CloseBtn" Grid.Column="3" Content="✕" Width="36" Height="30" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" FontSize="14" Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="#e94560"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            
            <!-- Memory & History Toggle Bar -->
            <Border Grid.Row="1" Background="{StaticResource BgSecondary}" Padding="10,5" BorderBrush="{StaticResource GlassBorder}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="MemoryIndicator" Grid.Column="0" Text="" Style="{StaticResource MemoryStyle}" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBlock x:Name="HistoryPreview" Grid.Column="1" Text="" Style="{StaticResource LabelStyle}" TextAlignment="Right" VerticalAlignment="Center" Margin="5,0" TextTrimming="CharacterEllipsis"/>
                    <Button x:Name="MemoryClearBtn" Grid.Column="2" Content="MC" Width="32" Height="22" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" FontSize="11" Click="MemoryClear_Click" Margin="2,0"/>
                    <Button x:Name="HistoryToggleBtn" Grid.Column="3" Content="☰" Width="32" Height="22" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" FontSize="14" Click="HistoryToggle_Click" Margin="5,0,0,0"/>
                </Grid>
            </Border>
            
            <!-- Main Content -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="HistoryCol" Width="0"/>
                </Grid.ColumnDefinitions>
                
                <!-- Calculator Tabs -->
                <TabControl x:Name="MainTabs" Grid.Column="0" Background="Transparent" BorderThickness="0">
                    
                    <!-- Standard Calculator -->
                    <TabItem Header="Standard">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Display -->
                            <Border Grid.Row="0" Background="{StaticResource BgSecondary}" CornerRadius="12" Padding="20,15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock x:Name="StandardExpression" Text="" Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource DisplayFont}" FontSize="16" TextAlignment="Right" TextTrimming="CharacterEllipsis" Height="24"/>
                                    <TextBlock x:Name="StandardDisplay" Text="0" Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource DisplayFont}" FontSize="42" TextAlignment="Right" FontWeight="Light"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Memory Buttons -->
                            <UniformGrid Grid.Row="1" Rows="1" Columns="5" Margin="0,0,0,10" Height="32">
                                <Button Content="MC" Style="{StaticResource FunctionButton}" FontSize="12" Click="MemoryClear_Click"/>
                                <Button Content="MR" Style="{StaticResource FunctionButton}" FontSize="12" Click="MemoryRecall_Click"/>
                                <Button Content="M+" Style="{StaticResource FunctionButton}" FontSize="12" Click="MemoryAdd_Click"/>
                                <Button Content="M-" Style="{StaticResource FunctionButton}" FontSize="12" Click="MemorySubtract_Click"/>
                                <Button Content="MS" Style="{StaticResource FunctionButton}" FontSize="12" Click="MemoryStore_Click"/>
                            </UniformGrid>
                            
                            <!-- Buttons -->
                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Row 1 -->
                                <Button Grid.Row="0" Grid.Column="0" Content="%" Style="{StaticResource FunctionButton}" Click="Percent_Click"/>
                                <Button Grid.Row="0" Grid.Column="1" Content="CE" Style="{StaticResource ClearButton}" Click="ClearEntry_Click"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="C" Style="{StaticResource ClearButton}" Click="ClearAll_Click"/>
                                <Button Grid.Row="0" Grid.Column="3" Content="⌫" Style="{StaticResource ClearButton}" Click="Backspace_Click"/>
                                
                                <!-- Row 2 -->
                                <Button Grid.Row="1" Grid.Column="0" Content="¹⁄ₓ" Style="{StaticResource FunctionButton}" Click="Reciprocal_Click"/>
                                <Button Grid.Row="1" Grid.Column="1" Content="x²" Style="{StaticResource FunctionButton}" Click="Square_Click"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="√x" Style="{StaticResource FunctionButton}" Click="SquareRoot_Click"/>
                                <Button Grid.Row="1" Grid.Column="3" Content="÷" Style="{StaticResource OperatorButton}" Click="Operator_Click"/>
                                
                                <!-- Row 3 -->
                                <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="2" Grid.Column="3" Content="×" Style="{StaticResource OperatorButton}" Click="Operator_Click"/>
                                
                                <!-- Row 4 -->
                                <Button Grid.Row="3" Grid.Column="0" Content="4" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="3" Grid.Column="1" Content="5" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="3" Grid.Column="2" Content="6" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="3" Grid.Column="3" Content="−" Style="{StaticResource OperatorButton}" Click="Operator_Click"/>
                                
                                <!-- Row 5 -->
                                <Button Grid.Row="4" Grid.Column="0" Content="1" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="4" Grid.Column="1" Content="2" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="4" Grid.Column="2" Content="3" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="4" Grid.Column="3" Content="+" Style="{StaticResource OperatorButton}" Click="Operator_Click"/>
                                
                                <!-- Row 6 -->
                                <Button Grid.Row="5" Grid.Column="0" Content="±" Style="{StaticResource CalcButton}" Click="Negate_Click"/>
                                <Button Grid.Row="5" Grid.Column="1" Content="0" Style="{StaticResource CalcButton}" Click="Number_Click"/>
                                <Button Grid.Row="5" Grid.Column="2" Content="." Style="{StaticResource CalcButton}" Click="Decimal_Click"/>
                                <Button Grid.Row="5" Grid.Column="3" Content="=" Style="{StaticResource EqualsButton}" Click="Equals_Click"/>
                            </Grid>
                        </Grid>
                    </TabItem>
                    
                    <!-- Scientific Calculator -->
                    <TabItem Header="Scientific">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Display -->
                            <Border Grid.Row="0" Background="{StaticResource BgSecondary}" CornerRadius="12" Padding="20,15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock x:Name="ScientificExpression" Text="" Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource DisplayFont}" FontSize="16" TextAlignment="Right" TextTrimming="CharacterEllipsis" Height="24"/>
                                    <TextBlock x:Name="ScientificDisplay" Text="0" Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource DisplayFont}" FontSize="36" TextAlignment="Right" FontWeight="Light"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Memory + Angle Mode -->
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <UniformGrid Grid.Column="0" Rows="1" Columns="5" Height="30">
                                    <Button Content="MC" Style="{StaticResource FunctionButton}" FontSize="11" Click="MemoryClear_Click"/>
                                    <Button Content="MR" Style="{StaticResource FunctionButton}" FontSize="11" Click="MemoryRecall_Click"/>
                                    <Button Content="M+" Style="{StaticResource FunctionButton}" FontSize="11" Click="MemoryAdd_Click"/>
                                    <Button Content="M-" Style="{StaticResource FunctionButton}" FontSize="11" Click="MemorySubtract_Click"/>
                                    <Button Content="MS" Style="{StaticResource FunctionButton}" FontSize="11" Click="MemoryStore_Click"/>
                                </UniformGrid>
                                <ToggleButton x:Name="DegRadToggle" Grid.Column="2" Content="DEG" Width="50" Height="30" Background="{StaticResource BtnFunction}" Foreground="{StaticResource TextPrimary}" BorderThickness="0" FontSize="11" FontWeight="SemiBold" Checked="DegRadToggle_Checked" Unchecked="DegRadToggle_Unchecked"/>
                            </Grid>
                            
                            <!-- Scientific Buttons -->
                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Row 1: Scientific functions -->
                                <Button Grid.Row="0" Grid.Column="0" Content="x²" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciSquare_Click"/>
                                <Button Grid.Row="0" Grid.Column="1" Content="xʸ" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciPower_Click"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="x!" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciFactorial_Click"/>
                                <Button Grid.Row="0" Grid.Column="3" Content="π" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciPi_Click"/>
                                <Button Grid.Row="0" Grid.Column="4" Content="e" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciE_Click"/>
                                
                                <!-- Row 2: Trig -->
                                <Button Grid.Row="1" Grid.Column="0" Content="sin" Style="{StaticResource FunctionButton}" FontSize="14" Click="SciSin_Click"/>
                                <Button Grid.Row="1" Grid.Column="1" Content="cos" Style="{StaticResource FunctionButton}" FontSize="14" Click="SciCos_Click"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="tan" Style="{StaticResource FunctionButton}" FontSize="14" Click="SciTan_Click"/>
                                <Button Grid.Row="1" Grid.Column="3" Content="log" Style="{StaticResource FunctionButton}" FontSize="14" Click="SciLog_Click"/>
                                <Button Grid.Row="1" Grid.Column="4" Content="ln" Style="{StaticResource FunctionButton}" FontSize="14" Click="SciLn_Click"/>
                                
                                <!-- Row 3: More functions -->
                                <Button Grid.Row="2" Grid.Column="0" Content="√" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciSqrt_Click"/>
                                <Button Grid.Row="2" Grid.Column="1" Content="∛" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciCbrt_Click"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="%" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciPercent_Click"/>
                                <Button Grid.Row="2" Grid.Column="3" Content="(" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciParenOpen_Click"/>
                                <Button Grid.Row="2" Grid.Column="4" Content=")" Style="{StaticResource FunctionButton}" FontSize="16" Click="SciParenClose_Click"/>
                                
                                <!-- Row 4 -->
                                <Button Grid.Row="3" Grid.Column="0" Content="7" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="3" Grid.Column="1" Content="8" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="3" Grid.Column="2" Content="9" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="3" Grid.Column="3" Content="÷" Style="{StaticResource OperatorButton}" Click="SciOperator_Click"/>
                                <Button Grid.Row="3" Grid.Column="4" Content="1/x" Style="{StaticResource FunctionButton}" FontSize="14" Click="SciReciprocal_Click"/>
                                
                                <!-- Row 5 -->
                                <Button Grid.Row="4" Grid.Column="0" Content="4" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="4" Grid.Column="1" Content="5" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="4" Grid.Column="2" Content="6" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="4" Grid.Column="3" Content="×" Style="{StaticResource OperatorButton}" Click="SciOperator_Click"/>
                                <Button Grid.Row="4" Grid.Column="4" Content="±" Style="{StaticResource CalcButton}" Click="SciNegate_Click"/>
                                
                                <!-- Row 6 -->
                                <Button Grid.Row="5" Grid.Column="0" Content="1" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="5" Grid.Column="1" Content="2" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="5" Grid.Column="2" Content="3" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="5" Grid.Column="3" Content="−" Style="{StaticResource OperatorButton}" Click="SciOperator_Click"/>
                                <Button Grid.Row="5" Grid.Column="4" Content="CE" Style="{StaticResource ClearButton}" Click="SciClearEntry_Click"/>
                                
                                <!-- Row 7 -->
                                <Button Grid.Row="6" Grid.Column="0" Content="0" Style="{StaticResource CalcButton}" Click="SciNumber_Click"/>
                                <Button Grid.Row="6" Grid.Column="1" Content="." Style="{StaticResource CalcButton}" Click="SciDecimal_Click"/>
                                <Button Grid.Row="6" Grid.Column="2" Content="C" Style="{StaticResource ClearButton}" Click="SciClearAll_Click"/>
                                <Button Grid.Row="6" Grid.Column="3" Content="+" Style="{StaticResource OperatorButton}" Click="SciOperator_Click"/>
                                <Button Grid.Row="6" Grid.Column="4" Content="=" Style="{StaticResource EqualsButton}" Click="SciEquals_Click"/>
                            </Grid>
                        </Grid>
                    </TabItem>
                    
                    <!-- Age Calculator -->
                    <TabItem Header="Age">
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Title -->
                                <TextBlock Grid.Row="0" Text="📅 Age Calculator" Foreground="{StaticResource Accent}" FontFamily="Segoe UI" FontSize="24" FontWeight="Bold" TextAlignment="Center" Margin="0,10,0,20"/>
                                
                                <!-- Birthdate Input -->
                                <Border Grid.Row="1" Background="{StaticResource BgSecondary}" CornerRadius="12" Padding="20,15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Select Your Birth Date" Style="{StaticResource LabelStyle}" Margin="0,0,0,10"/>
                                        <DatePicker x:Name="BirthDatePicker" Width="200" Height="35" FontSize="16" HorizontalAlignment="Center" SelectedDateFormat="Long" CalendarOpened="BirthDatePicker_Opened"/>
                                        <Button Content="Calculate Age" Width="200" Height="40" Margin="0,15,0,0" Background="{StaticResource Accent}" Foreground="White" BorderThickness="0" FontSize="16" FontWeight="SemiBold" Click="CalculateAge_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource AccentHover}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Results -->
                                <StackPanel Grid.Row="2" x:Name="AgeResults" Visibility="Collapsed">
                                    <!-- Main Age -->
                                    <Border Grid.Row="2" Style="{StaticResource ResultBoxStyle}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Your Age" Style="{StaticResource LabelStyle}" TextAlignment="Center" Margin="0,0,0,5"/>
                                            <TextBlock x:Name="AgeMainText" Text="0 years, 0 months, 0 days" Style="{StaticResource ValueStyle}" FontSize="24" TextAlignment="Center" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Breakdown -->
                                    <Border Style="{StaticResource ResultBoxStyle}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Detailed Breakdown" Style="{StaticResource LabelStyle}" TextAlignment="Center" Margin="0,0,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,5">
                                                    <TextBlock x:Name="AgeYears" Text="0" Style="{StaticResource ValueStyle}" FontSize="22" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                                                    <TextBlock Text="Years" Style="{StaticResource LabelStyle}" TextAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,5">
                                                    <TextBlock x:Name="AgeMonths" Text="0" Style="{StaticResource ValueStyle}" FontSize="22" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                                                    <TextBlock Text="Months" Style="{StaticResource LabelStyle}" TextAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,5">
                                                    <TextBlock x:Name="AgeWeeks" Text="0" Style="{StaticResource ValueStyle}" FontSize="22" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Success}"/>
                                                    <TextBlock Text="Weeks" Style="{StaticResource LabelStyle}" TextAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,5">
                                                    <TextBlock x:Name="AgeDays" Text="0" Style="{StaticResource ValueStyle}" FontSize="22" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Success}"/>
                                                    <TextBlock Text="Days" Style="{StaticResource LabelStyle}" TextAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,5">
                                                    <TextBlock x:Name="AgeHours" Text="0" Style="{StaticResource ValueStyle}" FontSize="22" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Warning}"/>
                                                    <TextBlock Text="Hours" Style="{StaticResource LabelStyle}" TextAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,5">
                                                    <TextBlock x:Name="AgeMinutes" Text="0" Style="{StaticResource ValueStyle}" FontSize="22" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Warning}"/>
                                                    <TextBlock Text="Minutes" Style="{StaticResource LabelStyle}" TextAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,5">
                                                    <TextBlock x:Name="AgeSeconds" Text="0" Style="{StaticResource ValueStyle}" FontSize="22" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Text="Seconds" Style="{StaticResource LabelStyle}" TextAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,5">
                                                    <TextBlock x:Name="AgeHeartbeats" Text="0" Style="{StaticResource ValueStyle}" FontSize="22" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                                                    <TextBlock Text="Heartbeats" Style="{StaticResource LabelStyle}" TextAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Next Birthday -->
                                    <Border Style="{StaticResource ResultBoxStyle}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Next Birthday" Style="{StaticResource LabelStyle}" TextAlignment="Center" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="NextBirthdayText" Text="0 days away" Style="{StaticResource ValueStyle}" FontSize="20" TextAlignment="Center" Foreground="{StaticResource Success}"/>
                                            <TextBlock x:Name="NextBirthdayDate" Text="" Style="{StaticResource LabelStyle}" TextAlignment="Center" Margin="0,5,0,0"/>
                                            <TextBlock x:Name="NextBirthdayDay" Text="" Style="{StaticResource LabelStyle}" TextAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Birth Info -->
                                    <Border Style="{StaticResource ResultBoxStyle}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Birth Information" Style="{StaticResource LabelStyle}" TextAlignment="Center" Margin="0,0,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Born on: " Style="{StaticResource LabelStyle}" Margin="0,5,10,5"/>
                                                <TextBlock x:Name="BornDayOfWeek" Text="" Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueStyle}" FontSize="16"/>
                                                
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Zodiac: " Style="{StaticResource LabelStyle}" Margin="0,5,10,5"/>
                                                <TextBlock x:Name="ZodiacSign" Text="" Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}" FontSize="16"/>
                                                
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Chinese Zodiac: " Style="{StaticResource LabelStyle}" Margin="0,5,10,5"/>
                                                <TextBlock x:Name="ChineseZodiac" Text="" Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}" FontSize="16"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Milestones -->
                                    <Border Style="{StaticResource ResultBoxStyle}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Upcoming Milestones" Style="{StaticResource LabelStyle}" TextAlignment="Center" Margin="0,0,0,10"/>
                                            <StackPanel x:Name="MilestonesList"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
                
                <!-- History Panel -->
                <Border Grid.Column="1" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="History" Foreground="{StaticResource Accent}" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Padding="15,10"/>
                        <ListBox x:Name="HistoryList" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding Expression}" Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource DisplayFont}" FontSize="12"/>
                                        <TextBlock Text="{Binding Result}" Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource DisplayFont}" FontSize="16" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Status Bar -->
            <Border Grid.Row="3" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusBar" Text="Ready" Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" FontSize="10" VerticalAlignment="Center" Margin="15,0"/>
            </Border>
        </Grid>
    </Border>
</Window>
